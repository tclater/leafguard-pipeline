[flake8]
max-line-length = 100
exclude =
    .git,
    __pycache__,
    alembic/versions,
    .eggs,
    *.egg-info,
    dist,
    build
ignore =
    # whitespace before ':'
    E203,
    # line break before binary operator (Black-compatible)
    W503,
    # missing whitespace around operator (handled by other rules)
    E226
per-file-ignores =
    # Allow unused imports in __init__.py for re-exports
    __init__.py:F401
